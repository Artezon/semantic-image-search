// Project tasks configuration. See https://zed.dev/docs/tasks for documentation.

[
  {
    "label": "Run dev",
    "command": "npm run tauri dev",
  },
  {
    "label": "Build release (faster build)",
    "command": "npm run tauri build",
  },
  {
    "label": "Build release (distribution)",
    "command": "npm run tauri build -- -- -- --profile release-opt",
  },
  {
    "label": "Format frontend code",
    "command": "npm run format",
  },
  {
    "label": "Build vcpkg",
    "command": "cargo install cargo-vcpkg; cargo vcpkg -v build --manifest-path src-tauri/Cargo.toml",
  },
]
